{
  "manifest_version": 3,
  "name": "Strava Activity Filter",
  "version": "1.0.0",
  "description": "Hide specific activity types from your Strava dashboard feed",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://www.strava.com/*"],
  "content_scripts": [
    {
      "matches": ["https://www.strava.com/dashboard*", "https://www.strava.com/"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
